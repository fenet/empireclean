# Backend server
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_INVITE_CODE=replace-with-admin-invite-code

# PostgreSQL connection for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/empireclean?schema=public

# Optional mailer and analytics variables used by backend utilities
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
META_PIXEL_ID=
META_ACCESS_TOKEN=
